# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Node (not used at runtime, but in case tooling is added)
node_modules/
npm-debug.log*

# Build / packaging artifacts
*.zip
dist/
build/
web-ext-artifacts/

# Temp / scratch
*.tmp
_*.js
*.log

# Stray browser test-profile dirs (must never reach the repo or the store zip;
# Chrome/Edge reject any extension folder containing a "_"-prefixed dir except _locales).
/_vp2/
/_vp[0-9]*/
